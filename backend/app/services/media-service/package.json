{
  "name": "@backend/media-service",
  "version": "1.0.0",
  "description": "Media management microservice.",
  "main": "dist/index.js",
  "private": true,
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx watch src/index.ts",
    "start:local": "node dist/index.js",
    "test": "vitest run",
    "db:generate": "drizzle-kit generate --config=drizzle.config.ts",
    "db:migrate": "drizzle-kit migrate --config=drizzle.config.ts",
    "db:drop": "drizzle-kit drop"
  },
  "dependencies": {
    "@aws-sdk/client-eventbridge": "^3.616.0",
    "@aws-sdk/client-s3": "^3.1086.0",
    "@aws-sdk/client-sesv2": "^3.616.0",
    "@aws-sdk/s3-request-presigner": "^3.1086.0",
    "@backend/shared": "*",
    "@fastify/aws-lambda": "^4.1.0",
    "bcryptjs": "^2.4.3",
    "drizzle-orm": "^0.31.2",
    "fastify": "^5.10.0",
    "jsonwebtoken": "^9.0.2",
    "pg": "^8.12.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/node": "^20.14.10",
    "@types/pg": "^8.11.6",
    "drizzle-kit": "^0.22.8",
    "tsx": "^4.16.2",
    "typescript": "^5.5.3",
    "vitest": "^2.0.3"
  }
}
