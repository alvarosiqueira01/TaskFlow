{
  "name": "@task-manager/reporting-service",
  "version": "1.0.0",
  "private": true,
  "description": "Reporting Service - Read-only task, category and productivity projections",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx watch src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src --ext .ts",
    "db:generate": "drizzle-kit generate --config=drizzle.config.ts",
    "db:migrate": "drizzle-kit migrate --config=drizzle.config.ts",
    "db:drop": "drizzle-kit drop"
  },
  "dependencies": {
    "@backend/shared": "*",
    "@fastify/aws-lambda": "^4.1.0",
    "drizzle-orm": "^0.31.2",
    "fastify": "^5.10.0",
    "pg": "^8.12.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.14.10",
    "@types/pg": "^8.11.6",
    "@types/aws-lambda": "^8.10.138",
    "tsx": "^4.16.2",
    "typescript": "^5.5.3",
    "vitest": "^2.0.3"
  }
}
